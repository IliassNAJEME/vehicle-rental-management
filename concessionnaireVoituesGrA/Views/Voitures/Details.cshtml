@model concessionnaireVoituesGrA.Models.VoitureDto

@{
    ViewData["Title"] = "Détails de la Voiture";
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="text-white fw-bold display-6 mb-0">Détails <span class="text-gradient">Véhicule</span></h2>
                <p class="text-muted lead mt-2">Fiche complète de la @Model.Marque @Model.Modele.</p>
            </div>
            <div class="d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model?.Matricule" class="btn btn-primary px-4 rounded-pill shadow-sm">
                    <i class="fa-solid fa-pen-to-square me-2"></i> Modifier
                </a>
                <a asp-action="Index" class="btn btn-secondary px-4 rounded-pill shadow-sm">
                    <i class="fa-solid fa-arrow-left me-2"></i> Retour
                </a>
            </div>
        </div>

        <div class="glass p-1 rounded-4 shadow-lg overflow-hidden">
            <div class="row g-0">
                <div class="col-md-6 bg-dark bg-opacity-25 position-relative">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" alt="@Model.Marque @Model.Modele" class="w-100 h-100 object-fit-cover" style="min-height: 400px;" />
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center w-100 h-100 p-5" style="min-height: 400px;">
                            <i class="fa-solid fa-car text-muted opacity-25 fa-10x"></i>
                        </div>
                    }
                    <div class="position-absolute top-0 start-0 m-4">
                        <span class="badge bg-primary fs-6 px-3 py-2 rounded-pill shadow">@Model.Matricule</span>
                    </div>
                </div>
                
                <div class="col-md-6 p-5">
                    <h3 class="text-white fw-bold mb-1">@Model.Marque @Model.Modele</h3>
                    <p class="text-muted fs-5 mb-4"><i class="fa-regular fa-calendar me-2"></i>Modèle @Model.Annee</p>
                    
                    <hr class="border-secondary opacity-25 mb-4" />
                    
                    <div class="row g-4 mb-4">
                        <div class="col-6">
                            <div class="p-3 bg-dark bg-opacity-50 rounded-3 border border-secondary border-opacity-25 h-100">
                                <div class="text-uppercase text-muted small fw-bold mb-1 tracking-wide">Marque</div>
                                <div class="text-white fs-5">@Model.Marque</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-3 bg-dark bg-opacity-50 rounded-3 border border-secondary border-opacity-25 h-100">
                                <div class="text-uppercase text-muted small fw-bold mb-1 tracking-wide">Modèle</div>
                                <div class="text-white fs-5">@Model.Modele</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-3 bg-dark bg-opacity-50 rounded-3 border border-secondary border-opacity-25 h-100">
                                <div class="text-uppercase text-muted small fw-bold mb-1 tracking-wide">Année</div>
                                <div class="text-white fs-5">@Model.Annee</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-3 bg-dark bg-opacity-50 rounded-3 border border-secondary border-opacity-25 h-100">
                                <div class="text-uppercase text-muted small fw-bold mb-1 tracking-wide">Disponibilité</div>
                                @if(Model.EtatDisponibilite == "Disponible") {
                                    <div class="text-success fs-5 fw-bold"><i class="fa-solid fa-check-circle me-1"></i> Disponible</div>
                                } else {
                                    <div class="text-warning fs-5 fw-bold"><i class="fa-solid fa-clock me-1"></i> Louée</div>
                                }
                            </div>
                        </div>
                    </div>
                    
                    <div class="p-4 bg-primary bg-opacity-10 border border-primary border-opacity-25 rounded-4 mt-auto">
                        <div class="text-uppercase text-primary small fw-bold mb-1 tracking-wide">Tarif de Location</div>
                        <div class="d-flex align-items-baseline">
                            <h2 class="text-white fw-bold mb-0 me-2">@Model.PrixLocation MAD</h2>
                            <span class="text-muted">/ jour</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
