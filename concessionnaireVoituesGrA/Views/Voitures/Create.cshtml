@model concessionnaireVoituesGrA.Models.VoitureDto

@{
    ViewData["Title"] = "Ajouter une Voiture";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="d-flex align-items-center mb-4">
            <div class="bg-primary bg-opacity-25 p-3 rounded-circle me-3">
                <i class="fa-solid fa-plus text-primary fs-4"></i>
            </div>
            <div>
                <h2 class="text-white fw-bold mb-0">Ajouter une Voiture</h2>
                <p class="text-muted mb-0">Enrichissez votre flotte avec un nouveau véhicule premium.</p>
            </div>
        </div>

        <div class="glass p-5 rounded-4 shadow-lg position-relative overflow-hidden">
            <div class="position-absolute top-0 end-0 p-4 opacity-10">
                <i class="fa-solid fa-car-side fa-10x"></i>
            </div>
            
            <form asp-action="Create" enctype="multipart/form-data" class="position-relative z-index-1">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm rounded-3"></div>
                
                @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
                {
                    <div class="alert alert-danger shadow-sm rounded-3 border-0 bg-danger bg-opacity-10 text-danger mb-4">
                        <i class="fa-solid fa-triangle-exclamation me-2"></i> @ViewBag.ErrorMessage
                    </div>
                }

                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="form-group mb-0">
                            <label asp-for="Matricule" class="control-label text-uppercase small tracking-wide text-muted fw-bold mb-2"><i class="fa-solid fa-hashtag me-1"></i> Matricule</label>
                            <input asp-for="Matricule" class="form-control form-control-lg bg-dark bg-opacity-50 text-white border-secondary" placeholder="Ex: 123-A-45" />
                            <span asp-validation-for="Matricule" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>
                    
                    <div class="col-md-6">
                        <div class="form-group mb-0">
                            <label asp-for="Marque" class="control-label text-uppercase small tracking-wide text-muted fw-bold mb-2"><i class="fa-solid fa-tag me-1"></i> Marque</label>
                            <input asp-for="Marque" class="form-control form-control-lg bg-dark bg-opacity-50 text-white border-secondary" placeholder="Ex: BMW" />
                            <span asp-validation-for="Marque" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group mb-0">
                            <label asp-for="Modele" class="control-label text-uppercase small tracking-wide text-muted fw-bold mb-2"><i class="fa-solid fa-car me-1"></i> Modèle</label>
                            <input asp-for="Modele" class="form-control form-control-lg bg-dark bg-opacity-50 text-white border-secondary" placeholder="Ex: Serie 3" />
                            <span asp-validation-for="Modele" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group mb-0">
                            <label asp-for="Categorie" class="control-label text-uppercase small tracking-wide text-muted fw-bold mb-2"><i class="fa-solid fa-layer-group me-1"></i> Catégorie</label>
                            <select asp-for="Categorie" class="form-select form-select-lg bg-dark bg-opacity-50 text-white border-secondary">
                                <option value="">-- Choisir une catégorie --</option>
                                <option value="Berline">Berline</option>
                                <option value="SUV">SUV</option>
                                <option value="Citadine">Citadine</option>
                                <option value="Sport">Sport</option>
                                <option value="Utilitaire">Utilitaire</option>
                                <option value="Luxe">Luxe</option>
                            </select>
                            <span asp-validation-for="Categorie" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group mb-0">
                            <label asp-for="Annee" class="control-label text-uppercase small tracking-wide text-muted fw-bold mb-2"><i class="fa-regular fa-calendar me-1"></i> Année</label>
                            <input asp-for="Annee" class="form-control form-control-lg bg-dark bg-opacity-50 text-white border-secondary" placeholder="Ex: 2024" />
                            <span asp-validation-for="Annee" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="form-group mb-0">
                            <label asp-for="PrixLocation" class="control-label text-uppercase small tracking-wide text-muted fw-bold mb-2"><i class="fa-solid fa-money-bill-wave me-1"></i> Prix de Location (MAD/Jour)</label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-dark bg-opacity-50 border-secondary text-muted">MAD</span>
                                <input asp-for="PrixLocation" class="form-control bg-dark bg-opacity-50 text-white border-secondary border-start-0" placeholder="0.00" />
                            </div>
                            <span asp-validation-for="PrixLocation" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="form-group mb-0">
                            <label asp-for="ImageFile" class="control-label text-uppercase small tracking-wide text-muted fw-bold mb-2"><i class="fa-regular fa-image me-1"></i> Image du Véhicule (Optionnel)</label>
                            <input asp-for="ImageFile" type="file" class="form-control form-control-lg bg-dark bg-opacity-50 text-white border-secondary" accept="image/*" />
                            <div class="form-text text-muted small mt-2">Formats acceptés : JPG, PNG. Poids max : 5Mo.</div>
                            <span asp-validation-for="ImageFile" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>
                </div>

                <hr class="border-secondary opacity-25 my-5" />

                <div class="d-flex justify-content-between align-items-center">
                    <a asp-action="Index" class="btn btn-secondary px-4 py-2 rounded-pill shadow-sm">
                        <i class="fa-solid fa-arrow-left me-2"></i> Retour au Catalogue
                    </a>
                    <button type="submit" class="btn btn-primary px-5 py-2 rounded-pill shadow-lg fw-bold fs-5">
                        <i class="fa-solid fa-floppy-disk me-2"></i> Ajouter au Parc
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
