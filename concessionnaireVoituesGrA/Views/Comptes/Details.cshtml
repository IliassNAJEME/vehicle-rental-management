@model concessionnaireVoituesGrA.Models.CompteDto

@{
    ViewData["Title"] = "Détails du Compte";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="d-flex align-items-center mb-4">
            <div class="bg-info bg-opacity-25 p-3 rounded-circle me-3">
                <i class="fa-solid fa-address-card text-info fs-4"></i>
            </div>
            <div>
                <h2 class="text-white fw-bold mb-0">Détails du Compte</h2>
                <p class="text-muted mb-0">Informations complètes sur @Model.Username</p>
            </div>
        </div>

        <div class="glass p-1 rounded-4 shadow-lg overflow-hidden mb-4">
            <div class="row g-0">
                <div class="col-sm-4 bg-dark bg-opacity-50 d-flex flex-column align-items-center justify-content-center p-4" style="min-height: 200px;">
                    <div class="bg-secondary bg-opacity-50 rounded-circle d-flex align-items-center justify-content-center mb-3 shadow" style="width: 100px; height: 100px;">
                        <i class="fa-solid fa-user-shield text-white fs-1 opacity-75"></i>
                    </div>
                    @if(Model.Username.ToLower().Contains("admin"))
                    {
                        <span class="badge bg-danger bg-opacity-25 text-danger border border-danger border-opacity-25 px-3 py-2 rounded-pill font-monospace shadow-sm">
                            Administrateur
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-info bg-opacity-25 text-info border border-info border-opacity-25 px-3 py-2 rounded-pill font-monospace shadow-sm">
                            Client
                        </span>
                    }
                </div>
                <div class="col-sm-8 p-4 p-md-5 d-flex flex-column justify-content-center position-relative">
                    <div class="position-absolute top-0 end-0 p-3 opacity-10">
                        <i class="fa-solid fa-fingerprint fa-6x"></i>
                    </div>
                    
                    <h3 class="text-white fw-bold mb-1">@Model.Username</h3>
                    <hr class="border-secondary opacity-25 w-25 mb-4" />

                    <div>
                        <div class="text-uppercase small tracking-wide text-muted fw-bold mb-1"><i class="fa-solid fa-lock me-2"></i>Sécurité</div>
                        <div class="text-light fs-5 font-monospace">&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center">
            <a asp-action="Index" class="btn btn-secondary px-4 py-2 rounded-pill shadow-sm">
                <i class="fa-solid fa-arrow-left me-2"></i> Retour à la liste
            </a>
            <div>
                <a asp-action="Edit" asp-route-id="@Model?.Username" class="btn btn-primary px-4 py-2 rounded-pill shadow-lg me-2">
                    <i class="fa-solid fa-pen-to-square me-2"></i> Modifier
                </a>
                <a asp-action="Delete" asp-route-id="@Model?.Username" class="btn btn-danger px-4 py-2 rounded-pill shadow-lg">
                    <i class="fa-solid fa-trash me-2"></i> Supprimer
                </a>
            </div>
        </div>
    </div>
</div>
