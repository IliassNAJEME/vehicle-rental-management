@model concessionnaireVoituesGrA.Models.CompteDto
@{ ViewData["Title"] = "Inscription"; }

<div style="min-height:85vh;display:flex;align-items:center;justify-content:center;padding:2rem;">
<div style="width:100%;max-width:480px;">

    <div style="text-align:center;margin-bottom:2.5rem;">
        <div style="width:56px;height:56px;background:linear-gradient(135deg,#7C3AED,var(--color-primary-600));border-radius:16px;display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;">
            <i class="fa-solid fa-rocket" style="color:#fff;font-size:1.3rem;"></i>
        </div>
        <h1 style="font-family:var(--font-display);font-size:1.8rem;font-weight:800;color:#fff;margin:0;">Rejoignez RentACar</h1>
        <p style="color:var(--color-surface-400);margin:.5rem 0 0;font-size:.95rem;">Creez votre compte et reservez en 60 secondes</p>
    </div>

    <!-- Avantages -->
    <div style="display:flex;gap:1rem;margin-bottom:1.5rem;flex-wrap:wrap;">
        <div style="flex:1;min-width:120px;background:rgba(37,99,235,.08);border:1px solid rgba(37,99,235,.15);border-radius:10px;padding:.75rem;text-align:center;">
            <i class="fa-solid fa-bolt" style="color:var(--color-primary-400);display:block;margin-bottom:.25rem;"></i>
            <span style="font-size:.75rem;color:var(--color-surface-400);">Reservation instant</span>
        </div>
        <div style="flex:1;min-width:120px;background:rgba(16,185,129,.08);border:1px solid rgba(16,185,129,.15);border-radius:10px;padding:.75rem;text-align:center;">
            <i class="fa-solid fa-shield-halved" style="color:#34D399;display:block;margin-bottom:.25rem;"></i>
            <span style="font-size:.75rem;color:var(--color-surface-400);">100% securise</span>
        </div>
        <div style="flex:1;min-width:120px;background:rgba(245,158,11,.08);border:1px solid rgba(245,158,11,.15);border-radius:10px;padding:.75rem;text-align:center;">
            <i class="fa-solid fa-star" style="color:#FBBF24;display:block;margin-bottom:.25rem;"></i>
            <span style="font-size:.75rem;color:var(--color-surface-400);">Flotte premium</span>
        </div>
    </div>

    <div class="glass-panel" style="padding:2rem;">
        @if (ViewBag.MessageErreur != null)
        {
            <div class="alert-danger p-3 mb-4" style="border-radius:10px;display:flex;align-items:center;gap:10px;">
                <i class="fa-solid fa-circle-exclamation"></i>
                <span style="font-size:.88rem;">@ViewBag.MessageErreur</span>
            </div>
        }

        <form asp-action="Creer" method="post" id="register-form">
            @Html.AntiForgeryToken()
            <div class="mb-4">
                <label class="form-label" for="reg-username">
                    <i class="fa-regular fa-user me-1" style="color:var(--color-primary-500);"></i> Nom d'utilisateur
                </label>
                <input type="text" class="form-control" id="reg-username" name="Username"
                       placeholder="Choisissez un identifiant unique" autocomplete="username" 
                       minlength="3" maxlength="50" required autofocus />
                <div style="font-size:.75rem;color:var(--color-surface-500);margin-top:.4rem;">
                    Min. 3 caracteres, sans espaces
                </div>
            </div>
            <div class="mb-4">
                <label class="form-label" for="reg-password">
                    <i class="fa-solid fa-lock me-1" style="color:var(--color-primary-500);"></i> Mot de passe
                </label>
                <div style="position:relative;">
                    <input type="password" class="form-control" id="reg-password" name="Password"
                           placeholder="Minimum 6 caracteres" autocomplete="new-password"
                           minlength="6" required style="padding-right:3rem;" oninput="updateStrength(this.value)" />
                    <button type="button" onclick="togglePwd('reg-password',this)"
                            style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--color-surface-400);cursor:pointer;">
                        <i class="fa-regular fa-eye"></i>
                    </button>
                </div>
                <!-- Password strength bar -->
                <div style="margin-top:.5rem;">
                    <div style="height:4px;background:var(--color-surface-700);border-radius:2px;overflow:hidden;">
                        <div id="strength-bar" style="height:100%;width:0%;border-radius:2px;transition:all .3s ease;"></div>
                    </div>
                    <span id="strength-label" style="font-size:.72rem;color:var(--color-surface-500);"></span>
                </div>
            </div>
            <div class="mb-5">
                <label class="form-label" for="reg-confirm">
                    <i class="fa-solid fa-lock me-1" style="color:var(--color-primary-500);"></i> Confirmer le mot de passe
                </label>
                <input type="password" class="form-control" id="reg-confirm"
                       placeholder="Retapez votre mot de passe" autocomplete="new-password" required />
                <div id="match-msg" style="font-size:.75rem;margin-top:.4rem;display:none;"></div>
            </div>
            <button type="submit" class="btn-primary w-100" id="submit-btn" style="padding:1rem;font-size:1rem;border-radius:var(--radius-md);justify-content:center;">
                <i class="fa-solid fa-rocket me-2"></i> Creer mon compte
            </button>
        </form>

        <div style="text-align:center;margin-top:1.5rem;padding-top:1.5rem;border-top:1px solid rgba(255,255,255,0.05);">
            <p style="font-size:.88rem;color:var(--color-surface-400);margin:0;">
                Deja un compte ?
                <a asp-action="Authentifier" style="color:var(--color-primary-400);font-weight:600;"> Se connecter</a>
            </p>
        </div>
    </div>
</div>
</div>

@section Scripts {
<script>
function togglePwd(id, btn) {
    var input = document.getElementById(id);
    input.type = input.type === 'password' ? 'text' : 'password';
    btn.querySelector('i').className = input.type === 'password' ? 'fa-regular fa-eye' : 'fa-regular fa-eye-slash';
}

function updateStrength(val) {
    var bar = document.getElementById('strength-bar');
    var label = document.getElementById('strength-label');
    var score = 0;
    if (val.length >= 6) score++;
    if (val.length >= 10) score++;
    if (/[A-Z]/.test(val)) score++;
    if (/[0-9]/.test(val)) score++;
    if (/[^A-Za-z0-9]/.test(val)) score++;
    var colors = ['#EF4444','#F59E0B','#F59E0B','#10B981','#10B981'];
    var labels = ['','Faible','Moyen','Fort','Tres fort'];
    var widths = [0,25,50,75,100];
    bar.style.width = widths[score] + '%';
    bar.style.background = colors[score] || '#EF4444';
    label.textContent = labels[score] || '';
    label.style.color = colors[score] || '#EF4444';
}

document.getElementById('reg-confirm').addEventListener('input', function() {
    var pwd = document.getElementById('reg-password').value;
    var msg = document.getElementById('match-msg');
    msg.style.display = 'block';
    if (this.value === pwd && this.value.length > 0) {
        msg.textContent = '✓ Les mots de passe correspondent';
        msg.style.color = '#34D399';
    } else {
        msg.textContent = '✗ Les mots de passe ne correspondent pas';
        msg.style.color = '#FCA5A5';
    }
});

document.getElementById('register-form').addEventListener('submit', function(e) {
    var pwd = document.getElementById('reg-password').value;
    var confirm = document.getElementById('reg-confirm').value;
    if (pwd !== confirm) {
        e.preventDefault();
        document.getElementById('match-msg').textContent = '✗ Les mots de passe ne correspondent pas';
        document.getElementById('match-msg').style.color = '#FCA5A5';
        document.getElementById('match-msg').style.display = 'block';
    }
});
</script>
}
