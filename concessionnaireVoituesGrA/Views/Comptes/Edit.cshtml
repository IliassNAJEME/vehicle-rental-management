@model concessionnaireVoituesGrA.Models.CompteDto

@{
    ViewData["Title"] = "Modifier le Compte";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="d-flex align-items-center mb-4">
            <div class="bg-primary bg-opacity-25 p-3 rounded-circle me-3">
                <i class="fa-solid fa-user-pen text-primary fs-4"></i>
            </div>
            <div>
                <h2 class="text-white fw-bold mb-0">Modifier le Compte</h2>
                <p class="text-muted mb-0">Mettez à jour les informations de sécurité pour @Model.Username.</p>
            </div>
        </div>

        <div class="glass p-5 rounded-4 shadow-lg position-relative overflow-hidden">
            <div class="position-absolute top-0 end-0 p-4 opacity-10">
                <i class="fa-solid fa-user-shield fa-10x"></i>
            </div>
            
            <form asp-action="Edit" class="position-relative z-index-1">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm rounded-3"></div>
                
                @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
                {
                    <div class="alert alert-danger shadow-sm rounded-3 border-0 bg-danger bg-opacity-10 text-danger mb-4">
                        <i class="fa-solid fa-triangle-exclamation me-2"></i> @ViewBag.ErrorMessage
                    </div>
                }

                <div class="row g-4">
                    <div class="col-md-12">
                        <div class="form-group mb-0">
                            <label asp-for="Username" class="control-label text-uppercase small tracking-wide text-muted fw-bold mb-2"><i class="fa-solid fa-user me-1"></i> Nom d'utilisateur</label>
                            <input asp-for="Username" class="form-control form-control-lg bg-dark bg-opacity-50 text-white border-secondary" readonly />
                            <span class="text-muted small mt-1 d-block"><i class="fa-solid fa-circle-info me-1"></i> L'identifiant du compte ne peut pas être modifié.</span>
                        </div>
                    </div>

                    <div class="col-md-12">
                        <div class="form-group mb-0">
                            <label asp-for="Password" class="control-label text-uppercase small tracking-wide text-muted fw-bold mb-2"><i class="fa-solid fa-lock me-1"></i> Nouveau Mot de Passe</label>
                            <input asp-for="Password" class="form-control form-control-lg bg-dark bg-opacity-50 text-white border-secondary" />
                            <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>
                </div>

                <hr class="border-secondary opacity-25 my-5" />

                <div class="d-flex justify-content-between align-items-center">
                    <a asp-action="Index" class="btn btn-secondary px-4 py-2 rounded-pill shadow-sm">
                        <i class="fa-solid fa-arrow-left me-2"></i> Retour
                    </a>
                    <button type="submit" class="btn btn-primary px-5 py-2 rounded-pill shadow-lg fw-bold fs-5">
                        <i class="fa-solid fa-check me-2"></i> Enregistrer
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
