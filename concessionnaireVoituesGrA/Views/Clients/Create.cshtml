@model concessionnaireVoituesGrA.Models.ClientDto

@{
    ViewData["Title"] = "Ajouter un Client";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="d-flex align-items-center mb-4">
            <div class="bg-primary bg-opacity-25 p-3 rounded-circle me-3">
                <i class="fa-solid fa-user-plus text-primary fs-4"></i>
            </div>
            <div>
                <h2 class="text-white fw-bold mb-0">Nouveau Client</h2>
                <p class="text-muted mb-0">Enregistrez un nouveau client dans la base de données.</p>
            </div>
        </div>

        <div class="glass p-5 rounded-4 shadow-lg position-relative overflow-hidden">
            <div class="position-absolute top-0 end-0 p-4 opacity-10">
                <i class="fa-solid fa-id-card fa-10x"></i>
            </div>
            
            <form asp-action="Create" class="position-relative z-index-1">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm rounded-3"></div>
                
                @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
                {
                    <div class="alert alert-danger shadow-sm rounded-3 border-0 bg-danger bg-opacity-10 text-danger mb-4">
                        <i class="fa-solid fa-triangle-exclamation me-2"></i> @ViewBag.ErrorMessage
                    </div>
                }

                <div class="row g-4">
                    <div class="col-md-12">
                        <div class="form-group mb-0">
                            <label asp-for="CINE" class="control-label text-uppercase small tracking-wide text-muted fw-bold mb-2"><i class="fa-regular fa-id-card me-1"></i> CINE (Identifiant)</label>
                            <input asp-for="CINE" class="form-control form-control-lg bg-dark bg-opacity-50 text-white border-secondary" placeholder="Ex: AB123456" />
                            <span asp-validation-for="CINE" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>
                    
                    <div class="col-md-6">
                        <div class="form-group mb-0">
                            <label asp-for="Prenom" class="control-label text-uppercase small tracking-wide text-muted fw-bold mb-2"><i class="fa-solid fa-user me-1"></i> Prénom</label>
                            <input asp-for="Prenom" class="form-control form-control-lg bg-dark bg-opacity-50 text-white border-secondary" placeholder="Ex: Jean" />
                            <span asp-validation-for="Prenom" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group mb-0">
                            <label asp-for="Nom" class="control-label text-uppercase small tracking-wide text-muted fw-bold mb-2"><i class="fa-regular fa-user me-1"></i> Nom</label>
                            <input asp-for="Nom" class="form-control form-control-lg bg-dark bg-opacity-50 text-white border-secondary" placeholder="Ex: Dupont" />
                            <span asp-validation-for="Nom" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group mb-0">
                            <label asp-for="Tel" class="control-label text-uppercase small tracking-wide text-muted fw-bold mb-2"><i class="fa-solid fa-phone me-1"></i> Téléphone</label>
                            <input asp-for="Tel" class="form-control form-control-lg bg-dark bg-opacity-50 text-white border-secondary" placeholder="Ex: 0600000000" />
                            <span asp-validation-for="Tel" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="col-md-12">
                        <div class="form-group mb-0">
                            <label asp-for="Adresse" class="control-label text-uppercase small tracking-wide text-muted fw-bold mb-2"><i class="fa-solid fa-location-dot me-1"></i> Adresse</label>
                            <textarea asp-for="Adresse" class="form-control bg-dark bg-opacity-50 text-white border-secondary" rows="3" placeholder="Adresse complète"></textarea>
                            <span asp-validation-for="Adresse" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>
                </div>

                <hr class="border-secondary opacity-25 my-5" />

                <div class="d-flex justify-content-between align-items-center">
                    <a asp-action="Index" class="btn btn-secondary px-4 py-2 rounded-pill shadow-sm">
                        <i class="fa-solid fa-arrow-left me-2"></i> Retour
                    </a>
                    <button type="submit" class="btn btn-primary px-5 py-2 rounded-pill shadow-lg fw-bold fs-5">
                        <i class="fa-solid fa-floppy-disk me-2"></i> Enregistrer
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
