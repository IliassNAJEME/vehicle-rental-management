@model concessionnaireVoituesGrA.Models.ClientDto

@{
    ViewData["Title"] = "Supprimer un Client";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="d-flex align-items-center mb-4">
            <div class="bg-danger bg-opacity-25 p-3 rounded-circle me-3">
                <i class="fa-solid fa-user-xmark text-danger fs-4"></i>
            </div>
            <div>
                <h2 class="text-white fw-bold mb-0">Supprimer le Client</h2>
                <p class="text-muted mb-0">Cette action est irréversible.</p>
            </div>
        </div>

        <div class="alert alert-danger bg-danger bg-opacity-10 border-danger border-opacity-25 shadow-lg rounded-4 p-4 mb-4 d-flex align-items-center">
            <i class="fa-solid fa-triangle-exclamation fa-3x text-danger opacity-75 me-4"></i>
            <div>
                <h4 class="text-danger fw-bold mb-1">Êtes-vous absolument sûr ?</h4>
                <p class="text-danger opacity-75 mb-0">Vous êtes sur le point de supprimer le client <strong>@Model.Prenom @Model.Nom</strong> (@Model.CINE). Toutes ses données seront effacées.</p>
            </div>
        </div>

        <div class="glass p-4 rounded-4 shadow-sm mb-4">
            <div class="row">
                <div class="col-sm-6 mb-3 mb-sm-0">
                    <div class="text-uppercase small tracking-wide text-muted fw-bold mb-1">Identité</div>
                    <div class="text-white fs-5">@Model.Prenom @Model.Nom</div>
                </div>
                <div class="col-sm-6">
                    <div class="text-uppercase small tracking-wide text-muted fw-bold mb-1">CINE</div>
                    <div class="text-white font-monospace fs-5">@Model.CINE</div>
                </div>
            </div>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="CINE" />
            <div class="d-flex justify-content-between align-items-center">
                <a asp-action="Index" class="btn btn-secondary px-4 py-2 rounded-pill shadow-sm">
                    <i class="fa-solid fa-arrow-left me-2"></i> Annuler
                </a>
                <button type="submit" class="btn btn-danger px-5 py-2 rounded-pill shadow-lg fw-bold fs-5">
                    <i class="fa-solid fa-trash me-2"></i> Confirmer la suppression
                </button>
            </div>
        </form>
    </div>
</div>
