@model concessionnaireVoituesGrA.Models.ClientDto

@{
    ViewData["Title"] = "Détails du Client";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="d-flex align-items-center mb-4">
            <div class="bg-info bg-opacity-25 p-3 rounded-circle me-3">
                <i class="fa-solid fa-address-card text-info fs-4"></i>
            </div>
            <div>
                <h2 class="text-white fw-bold mb-0">Détails du Client</h2>
                <p class="text-muted mb-0">Informations complètes sur @Model.Prenom @Model.Nom</p>
            </div>
        </div>

        <div class="glass p-1 rounded-4 shadow-lg overflow-hidden mb-4">
            <div class="row g-0">
                <div class="col-sm-4 bg-dark bg-opacity-50 d-flex flex-column align-items-center justify-content-center p-4" style="min-height: 200px;">
                    <div class="bg-secondary bg-opacity-50 rounded-circle d-flex align-items-center justify-content-center mb-3 shadow" style="width: 100px; height: 100px;">
                        <i class="fa-solid fa-user text-white fs-1 opacity-75"></i>
                    </div>
                    <span class="badge bg-primary bg-opacity-25 text-primary border border-primary border-opacity-25 px-3 py-2 rounded-pill font-monospace shadow-sm">
                        CINE : @Model.CINE
                    </span>
                </div>
                <div class="col-sm-8 p-4 p-md-5 d-flex flex-column justify-content-center position-relative">
                    <div class="position-absolute top-0 end-0 p-3 opacity-10">
                        <i class="fa-solid fa-fingerprint fa-6x"></i>
                    </div>
                    
                    <h3 class="text-white fw-bold mb-1">@Model.Prenom @Model.Nom</h3>
                    <hr class="border-secondary opacity-25 w-25 mb-4" />

                    <div class="mb-3">
                        <div class="text-uppercase small tracking-wide text-muted fw-bold mb-1"><i class="fa-solid fa-phone me-2"></i>Téléphone</div>
                        <div class="text-light fs-5">@Model.Tel</div>
                    </div>
                    
                    <div>
                        <div class="text-uppercase small tracking-wide text-muted fw-bold mb-1"><i class="fa-solid fa-location-dot me-2"></i>Adresse</div>
                        <div class="text-light fs-5">@Model.Adresse</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center">
            <a asp-action="Index" class="btn btn-secondary px-4 py-2 rounded-pill shadow-sm">
                <i class="fa-solid fa-arrow-left me-2"></i> Retour à la liste
            </a>
            <div>
                <a asp-action="Edit" asp-route-id="@Model?.CINE" class="btn btn-primary px-4 py-2 rounded-pill shadow-lg me-2">
                    <i class="fa-solid fa-pen-to-square me-2"></i> Modifier
                </a>
                <a asp-action="Delete" asp-route-id="@Model?.CINE" class="btn btn-danger px-4 py-2 rounded-pill shadow-lg">
                    <i class="fa-solid fa-trash me-2"></i> Supprimer
                </a>
            </div>
        </div>
    </div>
</div>
